.venv/
__pycache__/
*.pyc
.pytest_cache/
.env
*.egg-info/

# Real anonymised validation samples are LOCAL-ONLY by default. Never commit
# real photographs, ground truth, or metadata unless a file is explicitly
# safe, anonymised, and approved for repository use (see
# docs/real_photo_validation_protocol.md).
samples/real_anonymised_images/*
samples/real_anonymised_ground_truth/*
samples/real_anonymised_metadata/*
!samples/real_anonymised_images/.gitkeep
!samples/real_anonymised_ground_truth/.gitkeep
!samples/real_anonymised_metadata/.gitkeep

# Real-capture rawBraille validation samples are LOCAL-ONLY by default
# (Stage 3D-G5 intake location). Never commit real photographs/scans, expected
# rawBraille, or metadata unless a file is explicitly safe, anonymised, and
# approved. Cell-level (rawBraille) evaluation only - no English transcripts.
samples/real_rawbraille_images/*
samples/real_rawbraille_expected/*
samples/real_rawbraille_metadata/*
!samples/real_rawbraille_images/.gitkeep
!samples/real_rawbraille_expected/.gitkeep
!samples/real_rawbraille_metadata/.gitkeep

# Real-photo baseline evaluation reports are LOCAL-ONLY by default: they can
# contain real sample ids and capture metadata.
reports/

# External source materials (e.g. UKAAF UEB resources) are LOCAL-ONLY:
# downloaded documents, generated previews/thumbnails, and intake reports may
# contain copyrighted third-party content and must never be committed.
_external_sources/
resources/
external_sample_reports/
*.downloaded.pdf
*.downloaded.brf
*.downloaded.doc
*.downloaded.docx
