# insighted-braille-ocr-engine configuration
# Copy this file to .env and adjust values. Never commit a real .env file.

# Optional API key. When set, POST /ocr requires the key via either header:
#   X-API-Key: <value>
#   Authorization: Bearer <value>   (the form InsightEd AI's adapter sends)
# Leave empty to disable authentication (local development only).
OCR_ENGINE_API_KEY=

# Maximum accepted image size in megabytes (decoded bytes).
MAX_IMAGE_MB=10

# Maximum decoded pixel count (decompression-bomb guard).
MAX_IMAGE_PIXELS=40000000

# Logging level. The service never logs image data, transcription text,
# pupil data, or secrets at any level.
LOG_LEVEL=INFO

# Liblouis back-translation (optional). Requires the python 'louis' bindings
# and Liblouis tables to be installed separately. When unavailable, the
# built-in Grade 1 (uncontracted) fallback translator is used and a clear
# uncertainty flag is returned.
LIBLOUIS_ENABLED=true
LIBLOUIS_TABLE=en-ueb-g1.ctb
